{
  "name": "drummark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm:build": "node scripts/build_wasm.mjs",
    "wasm:watch": "node scripts/wasm_watch.mjs",
    "predev": "npm run build-docs && npm run wasm:build",
    "dev": "concurrently -n wasm,vite \"node scripts/wasm_watch.mjs\" \"vite --host\"",
    "prebuild": "npm run wasm:build",
    "build": "tsc -b && npm run build-docs && vite build && npm run bundle:report",
    "build-docs": "tsx build-docs.ts",
    "bundle:report": "node scripts/report_bundle.mjs",
    "network:audit": "node scripts/audit_render_network.mjs",
    "verify:split-wasm": "npm run build && npm test -- scripts/check_import_boundaries.test.mjs scripts/check_import_boundaries.production.test.mjs src/wasm/split_wasm_wrappers.test.ts src/hooks/useAppSettings.test.ts src/scoreState.test.ts src/renderer/svgSceneAdapter.test.ts src/renderer/svgParity.test.ts src/wasm/parser_layout_parity.test.ts src/cli_runtime.test.ts && npm run network:audit && npm run drummark -- docs/examples/overview.drum --format svg",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test:watch": "vitest",
    "drummark": "tsx src/cli.ts",
    "drummark:native": "cargo run --manifest-path crates/drummark-core/Cargo.toml --"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "preact": "^10.29.1",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@types/jsdom": "^28.0.1",
    "canvas": "^3.2.3",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  }
}
